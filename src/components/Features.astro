---
const features = [
  {
    icon: '📷',
    title: 'Scan, don\'t type',
    body: 'Read asset-tag barcodes and capture serial numbers with camera OCR. Tap-to-focus, zoom, and a flashlight toggle for the back of a dusty cart.',
  },
  {
    icon: '🏫',
    title: 'Multi-site inventory',
    body: 'Track every device across every school and sub-location. Sticky location keeps you entering fast at one site, then switch with a tap.',
  },
  {
    icon: '🔎',
    title: 'Live search & filtering',
    body: 'Full-text search across the inventory with instant filtering by site, device type, and manufacturer.',
  },
  {
    icon: '👥',
    title: 'Role-based access',
    body: 'Super Admins, Admins, Auditors, and Read-Only users. Auditors see only their assigned sites; PIN login keeps it locked down.',
  },
  {
    icon: '📤',
    title: 'Export that fits your system',
    body: 'CSV in Standard or AssetTiger format, filtered by site or date range. Share to Excel, Numbers, Google Sheets, or Files.',
  },
  {
    icon: '🖨️',
    title: 'AirPrint reports',
    body: 'Generate clean, district-branded HTML reports and print them straight from your phone or iPad.',
  },
  {
    icon: '🛡️',
    title: 'Duplicate detection',
    body: 'Catch repeated serials and asset tags automatically, with a clear Update / Save-as-new / Cancel resolution.',
  },
  {
    icon: '🎨',
    title: 'District branding',
    body: 'Add your logo and colors, set report headers and footers, and choose which columns appear on exports and prints.',
  },
];
---
<section id="features" class="py-20 md:py-28 bg-slate-50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center mb-14">
      <p class="text-sm font-semibold tracking-widest uppercase text-brand-700 mb-3">
        What it does
      </p>
      <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-slate-900">
        Everything an audit needs. Nothing it doesn't.
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
      {features.map((f) => (
        <div class="bg-white rounded-2xl p-6 ring-1 ring-slate-200/80 hover:ring-brand-300 hover:shadow-lg transition">
          <div class="text-3xl mb-3" aria-hidden="true">{f.icon}</div>
          <h3 class="font-display font-bold text-slate-900 mb-2">{f.title}</h3>
          <p class="text-sm text-slate-600 leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
